<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Modern Order Page</title>
    <script src="https://js.stripe.com/v3/"></script>
    <style>
        body { font-family: -apple-system, sans-serif; display: flex; justify-content: center; padding: 50px; background: #f9f9f9; }
        .product-card { background: white; padding: 2rem; border-radius: 12px; box-shadow: 0 4px 6px rgba(0,0,0,0.1); width: 300px; text-align: center; }
        .btn { background: #635bff; color: white; border: none; padding: 12px 24px; border-radius: 6px; cursor: pointer; font-weight: 600; width: 100%; }
        .btn:hover { background: #4b45cc; }
    </style>
</head>
<body>
    <div class="product-card">
        <img src="https://via.placeholder.com/150" alt="Product" style="border-radius: 8px; margin-bottom: 1rem;">
        <h2>Premium Access</h2>
        <p style="color: #666;">$29.00 USD / one-time</p>
        <button id="checkout-button" class="btn">Proceed to Payment</button>
    </div>

    <script>
        const checkoutButton = document.getElementById('checkout-button');
        checkoutButton.addEventListener('click', async () => {
            // Call your backend to create a Checkout Session
            const response = await fetch('/create-checkout-session', { method: 'POST' });
            const session = await response.json();
            
            // Redirect to Stripe Checkout
            const stripe = Stripe('your_publishable_key_here');
            stripe.redirectToCheckout({ sessionId: session.id });
        });
    </script>
</body>
</html>
